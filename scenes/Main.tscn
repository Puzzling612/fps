; ─────── Tactical AI director ───────
[node name="EnemyDirector" type="Node" parent="."]
script = ExtResource("ExtScr_Director")

; ─────── Enemy spawner (spawn points read from group "enemy_spawn") ───────
[node name="EnemySpawner" type="Node3D" parent="."]
script = ExtResource("ExtScr_Spawner")
enemy_scene = ExtResource("ExtPS_Enemy")

; ─────── Pickup spawner (points read from group "pickup_point") ───────
[node name="PickupSpawner" type="Node3D" parent="."]
